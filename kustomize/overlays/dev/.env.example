# Cấu hình PostgreSQL
DB_USER=opendatacube
DB_PASSWORD=your_db_password_here

# Cấu hình MinIO
MINIO_USER=minioadmin
MINIO_PASSWORD=your_minio_password_here

# Cấu hình Token bảo mật cho Jupyter và Proxy
# (Lưu ý: Trong môi trường thực tế, nên tạo token bằng chuỗi ngẫu nhiên, ví dụ chạy lệnh: openssl rand -hex 32)
JUPYTER_TOKEN=your_jupyter_token_here
CONFIGPROXY_AUTH_TOKEN=your_configproxy_auth_token_here